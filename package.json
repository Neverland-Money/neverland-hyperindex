{
  "name": "neverland-hyperindex",
  "version": "1.0.0",
  "description": "Neverland Protocol Indexer - Envio HyperIndex",
  "scripts": {
    "codegen": "envio codegen",
    "dev": "envio dev",
    "start": "envio start",
    "stop": "envio stop",
    "local:docker:up": "envio local docker up",
    "local:docker:down": "envio local docker down",
    "format": "prettier --write \"src/**/*.ts\" \"abis/**/*.json\" \"*.json\" \"*.yaml\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"abis/**/*.json\" \"*.json\" \"*.yaml\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test:build": "tsc -p tsconfig.json --outDir dist-test --sourceMap",
    "test": "npm run test:build && node --test dist-test/src/__tests__/*.test.js",
    "test:coverage": "npm run test:build && c8 --reporter=text --reporter=lcov --reporter=html node --test dist-test/src/__tests__/*.test.js",
    "test:coverage:check": "npm run test:coverage -- --check-coverage --lines 100 --functions 100 --branches 100 --statements 100",
    "type-check": "envio codegen && tsc --noEmit",
    "prepare": "husky",
    "prod:deploy": "./deploy.sh",
    "prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "prod:down": "docker compose -f docker-compose.prod.yml down",
    "prod:restart": "docker compose -f docker-compose.prod.yml restart",
    "prod:restart:indexer": "docker compose -f docker-compose.prod.yml restart indexer",
    "prod:ps": "docker compose -f docker-compose.prod.yml ps",
    "prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "prod:logs:indexer": "docker compose -f docker-compose.prod.yml logs -f indexer",
    "prod:logs:cloudflared": "docker compose -f docker-compose.prod.yml logs -f cloudflared",
    "prod:logs:postgres": "docker compose -f docker-compose.prod.yml logs -f postgres",
    "prod:logs:tail": "docker compose -f docker-compose.prod.yml logs --tail=100 indexer",
    "prod:logs:errors": "docker compose -f docker-compose.prod.yml logs indexer | grep -i error",
    "prod:stats": "docker stats neverland-indexer neverland-postgres neverland-cloudflared --no-stream",
    "prod:health": "docker exec neverland-indexer curl -fsS http://hasura:8080/healthz && echo ' OK' || echo 'Health check failed'",
    "prod:db": "docker exec -it neverland-postgres psql -U postgres -d envio",
    "prod:db:backup": "docker exec neverland-postgres pg_dump -U postgres envio > backup-$(date +%Y%m%d-%H%M%S).sql",
    "prod:update": "git pull && docker compose -f docker-compose.prod.yml up -d --build indexer",
    "prod:resync": "docker compose -f docker-compose.prod.yml down -v && docker compose -f docker-compose.prod.yml up -d",
    "staging:up": "docker compose -f docker-compose.staging.yml up -d",
    "staging:down": "docker compose -f docker-compose.staging.yml down -v",
    "staging:logs": "docker compose -f docker-compose.staging.yml logs -f indexer-staging",
    "staging:status": "docker compose -f docker-compose.staging.yml ps",
    "staging:health": "docker exec neverland-indexer-staging curl -fsS http://hasura-staging:8080/healthz && echo ' OK' || echo 'Staging health check failed'",
    "prod:upgrade": "./zero-downtime-update.sh",
    "query:voting-power": "tsx scripts/query-voting-power.ts"
  },
  "c8": {
    "all": true,
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/__tests__/**",
      "**/handlers/lp.ts",
      "coverage/**",
      "dist-test/**",
      "generated/**",
      ".prettierrc.js",
      "eslint.config.js"
    ],
    "exclude-after-remap": true
  },
  "keywords": [
    "envio",
    "indexer",
    "neverland",
    "defi"
  ],
  "author": "",
  "license": "BUSL-1.1",
  "dependencies": {
    "envio": "^2.32.12",
    "viem": "^2.48.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "c8": "^10.1.3",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
