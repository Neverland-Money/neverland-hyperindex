# Envio HyperIndex Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Required: Envio API Token
# ============================================
# API token for HyperSync access. Required from November 3, 2025.
# Generate your token at: https://envio.dev/app/api-tokens
# For local development, this will be handled via automatic login from CLI
# For self-hosted deployments, this token is required
ENVIO_API_TOKEN=your_envio_api_token_here

# ============================================
# Optional: Custom RPC Endpoints
# ============================================
# HyperIndex V3 uses HyperSync for historical backfill and these RPC endpoints
# for realtime/head indexing when config.yaml sets `chains[].rpc[].for: realtime`.
ENVIO_MONAD_RPC_URL=https://rpc.monad.xyz
ENVIO_MONAD_WS_URL=wss://rpc.monad.xyz

# ============================================
# Optional: Database Configuration
# ============================================
# These are typically auto-managed by Envio. For self-hosted indexer runtime,
# Envio V3 uses ENVIO_PG_* variables.
# ENVIO_PG_HOST=localhost
# ENVIO_PG_PORT=5432
# ENVIO_PG_DATABASE=envio
# ENVIO_PG_USER=postgres
# ENVIO_PG_PASSWORD=postgres
# ENVIO_PG_SCHEMA=public
# ENVIO_PG_SSL_MODE=false

# Docker compose also uses POSTGRES_* to configure the Postgres container.
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=envio
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# ============================================
# Optional: Indexer Configuration
# ============================================
# ENVIO_TUI=false
# LOG_LEVEL=info
# METRICS_PORT=9090

# ============================================
# Optional: External Read Controls
# ============================================
# Master gate for ALL external calls (eth_call + future HTTP/IPFS). Default: off
# ENVIO_ENABLE_EXTERNAL_CALLS=true
# Enable eth_call-based reads (metadata, NFT balances). Requires ENVIO_ENABLE_EXTERNAL_CALLS=true. Default: off
# NOTE: Monad production indexing is event-only; shouldUseEthCalls() currently
# hard-returns false, so these eth_call gates are inert until that is re-enabled.
# ENVIO_ENABLE_ETH_CALLS=true

# Enable one-time on-chain NFT ownership baselines during settlement (defaults to off)
# ENVIO_ENABLE_NFT_CHAIN_SYNC=true
# Enable one-time on-chain LP baselines during settlement (defaults to off)
# ENVIO_ENABLE_LP_CHAIN_SYNC=true
# Enable on-chain sync on LeaderboardKeeper.UserSettled (defaults to off; inert
# while eth_calls are disabled)
# ENVIO_KEEPER_USER_SETTLED_SYNC_CHAIN=true

# ============================================
# Optional: Bootstrap Control
# ============================================
# Set to 'true' to disable the epoch-1 bootstrap seeding (used by tests so they
# can drive state purely from events). Default: unset = bootstrap enabled.
# ENVIO_DISABLE_BOOTSTRAP=true

# ============================================
# Optional: Backfill Leaderboard Gate
# ============================================
# Set to the CURRENT live Tide (epoch) number before a backfill to skip the heavy
# mid-epoch LeaderboardKeeper.UserSettled reserve sweeps for CLOSED past epochs
# (every epoch number below this value). Gap-period settlements that finalize an
# epoch, the live epoch itself, and any future epoch are always processed.
# Hugely speeds up backfill. Default: unset/0 = gate off (all settlements processed).
# CAVEAT: reserve points use a point-in-time multiplier sampled per settlement, so
# validate with scripts/compare-leaderboard-parity.ts before trusting it in prod.
# ENVIO_LEADERBOARD_LIVE_EPOCH=5

# Optional LP diagnostics
# DEBUG_LP_POINTS=true
